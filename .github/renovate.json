{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)apps/opencode/.*\\.yaml$"
      ],
      "matchStrings": [
        "image:\\s+ghcr\\.io/mmontes11/opencode:(?<currentValue>.+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mmontes11/docker-opencode",
      "packageNameTemplate": "mmontes11/docker-opencode"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)apps/open-webui/.*\\.yaml$"
      ],
      "matchStrings": [
        "repository:\\s+ghcr\\.io/open-webui/open-webui\\s*\\n\\s+tag:\\s+(?<currentValue>.+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "open-webui/open-webui",
      "packageNameTemplate": "open-webui/open-webui"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)apps/open-webui/.*\\.yaml$"
      ],
      "matchStrings": [
        "chart:\\s+open-webui\\s*\\n\\s+sourceRef:\\s*\\n\\s+kind:\\s+HelmRepository\\s*\\n\\s+name:\\s+open-webui\\s*\\n\\s+version:\\s+\"?(?<currentValue>[^\"]+)\"?"
      ],
      "datasourceTemplate": "helm",
      "packageNameTemplate": "open-webui",
      "registryUrlTemplate": "https://helm.openwebui.com/"
    }
  ]
}
