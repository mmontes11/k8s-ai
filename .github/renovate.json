{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/opencode/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+ghcr\\.io/mmontes11/opencode:(?<currentValue>.+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mmontes11/docker-opencode",
      "packageNameTemplate": "mmontes11/docker-opencode"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/open-webui/.*\\.yaml$/"
      ],
      "matchStrings": [
        "chart:\\s+open-webui\\s*\\n\\s+sourceRef:\\s*\\n\\s+kind:\\s+HelmRepository\\s*\\n\\s+name:\\s+open-webui\\s*\\n\\s+version:\\s+\"?(?<currentValue>[^\"]+)\"?"
      ],
      "datasourceTemplate": "helm",
      "packageNameTemplate": "open-webui",
      "registryUrlTemplate": "https://helm.openwebui.com/"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/n8n/.*\\.yaml$/"
      ],
      "matchStrings": [
        "ref:\\s*\\n\\s+tag:\\s+\"?(?<currentValue>[^\"]+)\"?"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "n8n-io/n8n-hosting"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apps/comfyui/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+ghcr\\.io/mmontes11/comfyui:(?<currentValue>.+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mmontes11/docker-comfyui",
      "packageNameTemplate": "mmontes11/docker-comfyui"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)infrastructure/llamacpp/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+ghcr\\.io/ggml-org/llama\\.cpp:(?<currentValue>full-cuda13-b[0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "ggml-org/llama.cpp",
      "registryUrlTemplate": "https://ghcr.io",
      "versioningTemplate": "regex:^full-cuda13-b(?<major>\\d+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)infrastructure/mcp-github/.*\\.yaml$/"
      ],
      "matchStrings": [
        "image:\\s+ghcr\\.io/github/github-mcp-server:(?<currentValue>.+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "github/github-mcp-server"
    }
  ]
}
